import "../main.del";

globalvar Number S_BHOP_MAX_SPEED;
globalvar Number S_BHOP_SPEED_RATE;
globalvar Boolean s_bhop_enabled;

playervar Boolean bhopping; // is the player bhopping
playervar Number bhop_speed; // bhop default speed multiplier
playervar Number bhop_rate; // bhop speed rate
playervar Number bhop_mult; // default movement speed multiplier (modified by mutators like berkserk and mobility)

Number min_speed: 6.93; // minimum bhop speed, adjust this along side the movement speed multiplier in custom game settings (usually the speed of walking backwards + strafing)

disabled rule: "---------------- Bhop ----------------"{}

void ResetSpeed() playervar "[Bhop] :: Reset Speed"
{
    StopChasingVariable(bhop_speed);
    bhopping = false;
    bhop_speed = bhop_mult;
    SetMoveSpeed(player, bhop_speed);
}

rule: "[Bhop] :: Init"
Event.OnPlayerJoin
{
    bhop_mult = 100;
    bhop_speed = bhop_mult;
    bhop_rate = S_BHOP_SPEED_RATE;
}

rule: "[Bhop] :: Auto Hop"
Event.OngoingPlayer
if (s_bhop_enabled)
if (IsOnGround())
if (IsJumpHeld())
{
    DisallowButton(player, Button.Jump);
    Wait(tickdur);
    AllowButton(player, Button.Jump);
}

rule: "[Bhop] :: Airborne"
Event.OngoingPlayer
if (s_bhop_enabled)
if (IsInAir())
if (HorizontalSpeedOf() > min_speed)
{
    ChaseVariableAtRate(bhop_speed, S_BHOP_MAX_SPEED, bhop_rate, RateChaseReevaluation.DestinationAndRate);
    bhopping = true;
}

rule: "[Bhop] :: Update Speed"
Event.OngoingPlayer
if (bhopping)
{
    SetMoveSpeed(player, bhop_speed);
    Wait(0.064);
    LoopIfConditionIsTrue();
}

rule: "[Bhop] :: Stop Chasing"
Event.OngoingPlayer
if (bhop_speed == bhop_mult || bhopping && bhop_speed == S_BHOP_MAX_SPEED)
{
    StopChasingVariable(bhop_speed);
}

rule: "[Bhop] :: Stop chasing"
Event.OngoingPlayer
if (bhopping || bhop_speed == S_BHOP_MAX_SPEED) 
if (HorizontalSpeedOf() < min_speed)
{
    ResetSpeed();
}

rule: "[Bhop] :: Stop if player is on ground"
Event.OngoingPlayer
if (IsOnGround())
if (bhop_speed > bhop_mult)
{
    WaitIfTrue(0.25);
    ResetSpeed();
}

rule: "[Bhop] :: Air Drag Reduction (T1mur4TR)"
Event.OngoingPlayer
if (bhopping)
if (IsInAir())
{
    ApplyImpulse(player, VelocityOf() * Vector(1, 0, 1), 30.792 / 1000 * Max(HorizontalSpeedOf() - 6.5, 0), Relative.ToWorld, ContraryMotion.Incorporate);

    // this rule fucks the server load which is why there is a longer wait than usual
    Wait(0.064);
    LoopIfConditionIsTrue();
}
