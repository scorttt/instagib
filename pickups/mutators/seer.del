import "../../main.del";
import ".mmain.del";

rule: "[Mutator] :: Seer : Set Status"
Event.OngoingPlayer
if (m_enabled[0])
{
    LogToInspector(<"Seer given to <0>", m_usr>);

    StopForcingPlayerOutlines(all, player);
    StartForcingPlayerOutlines(all, player, true, m_color[1], OutlineType.Always);
}