        buckshot_hp_player[30] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(bs_spread[1] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf() + bs_spread[1] * 6) 
        * 100, EnemyPlayers(), player, false);

        // upper left 6
        buckshot_hp_player[31] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(bs_spread[1] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf() - bs_spread[1] * 6) 
        * 100, EnemyPlayers(), player, false);

        // lower right 6
        buckshot_hp_player[32] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(-bs_spread[1] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf() + bs_spread[1] * 6) 
        * 100, EnemyPlayers(), player, false);

        // upper right 6
        buckshot_hp_player[33] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(-bs_spread[1] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf() - bs_spread[1] * 6) 
        * 100, EnemyPlayers(), player, false);

        // mid left 6
        buckshot_hp_player[34] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(bs_spread[0] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf()) 
        * 100, EnemyPlayers(), player, false);

        // mid right 6
        buckshot_hp_player[35] = RayCastHitPlayer(EyePosition(), EyePosition() + 
        WorldVectorOf(Vector(TangentFromDegrees(-bs_spread[0] * 6) * 100, 0, 0), player) + 
        DirectionFromAngles(HorizontalFacingAngleOf(), VerticalFacingAngleOf()) 
        * 100, EnemyPlayers(), player, false);
    }

    PlayEffect(all, PlayEffect.GoodExplosion, color_arr[2], buckshot_center, 0.2);

    CreateBeamEffect(all, BeamType.BadBeam, gun_pos, buckshot_center, color_arr[2], EffectRev.None);
    center_beam = LastCreatedEntity();

    for (num p = 0; p < buckshot_hp.Length; p++)
    {
        PlayEffect(all, PlayEffect.GoodExplosion, color_arr[2], buckshot_hp[p], 0.2);

        CreateBeamEffect(all, BeamType.BadBeam, gun_pos, buckshot_hp[p], color_arr[2], EffectRev.None);
        buckshot_beam[p] = LastCreatedEntity();
    }

    Kill(buckshot_hp_player, player);

    Wait(0.25);
    DestroyEffect(center_beam);

    DestroyEffect(buckshot_beam);

    charge_lvl = 0;
    charge_str = "○ ○ ○ ○ ○ ";
}