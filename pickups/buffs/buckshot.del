import "../../main.del";
import ".bmain.del";

globalvar num buckshot_pb;
globalvar num S_BUCKSHOT_SPREAD;
globalvar num S_BUCKSHOT_CHARGE_SPD;
globalvar str[] charge_arr;
playervar num charge_lvl;
playervar str charge_str;
playervar str hascharge_str;
playervar str nocharge_str;

disabled rule: "---------------- Buckshot ----------------"{}

rule: "[Buff] :: Buckshot : Create Orb"
if (match_started)
if (valid_map)
if (s_spawn_buff[2])
if (buckshot_pb == 100)
{
    buff_i = 2;
    CreateOrb();
}

rule: "[Buff] :: Buckshot : Collect"
Event.OngoingPlayer
if (HasSpawned())
if (!has_buff || buff_enabled[2])
if (can_pickup_buff[2])
if (DistanceBetween(buff_pos[2], PositionOf() + Up()) < S_PICKUP_RAD)
if (IsAlive())
{
    buff_str = "Buckshot";
    buff_i = 2;
    CollectBuff();
}

rule: "[Buff] :: Buckshot : Remove"
Event.OngoingPlayer
if (buff_enabled[2])
if (buff_ammo[2] <= 0)
{
    LogToInspector(<"Buckshot Disabled for <0>", player>);

    DestroyEffect(collected_buff_effect[2]);

    buff_enabled[2] = false;
    has_buff = false;
}

rule: "[Buff] :: Buckshot : Charge"
Event.OngoingPlayer
if (buff_enabled[2])
if (buff_ammo[2] > 1)
if (charge_lvl < 5)
if (IsAlive())
if (IsReloadHeld())
{
    WaitIfTrue(S_BUCKSHOT_CHARGE_SPD);
    PlayEffect(all, PlayEffect.GoodPickupEffect, color_arr[2], PositionOf(), 1);
    PlayEffect(player, PlayEffect.BuffImpactSound, Color.White, player, 50);
    charge_lvl++;
    
    buff_ammo[2]--;

    hascharge_str = StringSlice(charge_arr[0], 0, charge_lvl * 2);
    nocharge_str = StringSlice(charge_arr[1], 0, 10 - charge_lvl * 2);

    charge_str = hascharge_str + nocharge_str;

    LoopIfConditionIsTrue();
}

// i hate looking at this rule
rule: "[Buff] :: Buckshot : Fire Action - Welcome to hell"
Event.OngoingPlayer
if (buff_enabled[2])
if (buff_ammo[2] > 0)
