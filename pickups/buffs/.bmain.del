import "../../main.del";

import "wallbang.del";
import "ricochet.del";
import "buckshot.del";
import "prism.del";
import "ballista.del";
import "electro.del";
import "spark.del";
import "arc.del";
import "daybreak.del";
import "lightning.del";

globalvar Number[] S_BUFF_CD;
globalvar Number[] S_BUFF_AMMO;
globalvar Number[] buff_cd;
globalvar Boolean[] buff_timer;
globalvar Boolean[] s_spawn_buff;
globalvar String[] buff_txt;
globalvar Boolean s_buffs_enabled;
globalvar Boolean s_rand_buff_pos;
globalvar Boolean valid_map;
globalvar Vector[] buff_pos;
globalvar Boolean s_cd_ip_timer;
globalvar Number buff_i;
globalvar Color buff_color;
globalvar Color[] color_arr;
globalvar Any[] collected_buff_effect;
globalvar Boolean[] can_pickup_buff;
playervar Boolean has_buff;
playervar Boolean[] buff_enabled;
playervar Number[] buff_ammo;
playervar String buff_str;

disabled rule: "---------------- Buff ----------------"{}

void CollectBuff() playervar "[Buff] :: Buff Collection"
{
    can_pickup_buff[buff_i] = false;
    buff_color = color_arr[buff_i];
    BigMessage(player, buff_str);
    LogToInspector(<"<0> Enabled for <1>", buff_str, player>);

    if (!has_buff)
    {
        buff_enabled[buff_i] = true;
        has_buff = true;

        CreateEffect(IsAlive() ? all : null, Effect.GoodAura, buff_color, player, 0.5, EffectRev.VisibleToPositionAndRadius);
        collected_buff_effect[buff_i] = LastCreatedEntity();
    }

    if (buff_ammo[buff_i] < 0)
        buff_ammo[buff_i] = 0;

    buff_ammo[buff_i] += S_BUFF_AMMO[buff_i];

    // pickup effects
    PlayEffect(all, PlayEffect.GoodPickupEffect, buff_color, buff_pos[buff_i], 1);
    PlayEffect(all, PlayEffect.BuffExplosionSound, buff_color, buff_pos[buff_i], 200);

    buff_cd[buff_i] = S_BUFF_CD[buff_i];
    BuffCooldown();

    buff_i = -1;
    buff_color = null;
}

void BuffCooldown() "[Buff] :: Start Buff Timer"
{
    if (s_spawn_buff[buff_i] && buff_cd[buff_i] == S_BUFF_CD[buff_i])
    {
        buff_timer[buff_i] = true; // start timer

        switch (buff_i) // progress bar control
        {
            case (0):
                LogToInspector("Wallbang cooldown started");
                wallbang_pb = 0;
                ChaseVariableOverTime(wallbang_pb, 100, S_BUFF_CD[0], TimeChaseReevaluation.None);

                break;
            case (1):
                LogToInspector("Ricochet cooldown started");
                ricochet_pb = 0;
                ChaseVariableOverTime(ricochet_pb, 100, S_BUFF_CD[1], TimeChaseReevaluation.None);

                break;
            case (2):
                LogToInspector("Buckshot cooldown started");
                buckshot_pb = 0;
                ChaseVariableOverTime(buckshot_pb, 100, S_BUFF_CD[2], TimeChaseReevaluation.None);

                break;
            case (3):
                LogToInspector("Prism cooldown started");
                prism_pb = 0;
                ChaseVariableOverTime(prism_pb, 100, S_BUFF_CD[3], TimeChaseReevaluation.None);

                break;
            case (4):
                LogToInspector("Ballista cooldown started");
                bal_pb = 0;
                ChaseVariableOverTime(bal_pb, 100, S_BUFF_CD[4], TimeChaseReevaluation.None);
            
                break;
            case (5):
                LogToInspector("Electro cooldown started");
                electro_pb = 0;
                ChaseVariableOverTime(electro_pb, 100, S_BUFF_CD[5], TimeChaseReevaluation.None);
            
                break;
            case (6):
                LogToInspector("Spark cooldown started");
                sprk_pb = 0;
                ChaseVariableOverTime(sprk_pb, 100, S_BUFF_CD[6], TimeChaseReevaluation.None);

                break;
            case (7):
                LogToInspector("Arc cooldown started");
                arc_pb = 0;
                ChaseVariableOverTime(arc_pb, 100, S_BUFF_CD[7], TimeChaseReevaluation.None);

                break;
            case (8):
                LogToInspector("Daybreak cooldown started");
                dayb_pb = 0;
                ChaseVariableOverTime(dayb_pb, 100, S_BUFF_CD[8], TimeChaseReevaluation.None);

                break;
            case (9):
                LogToInspector("Lightning cooldown started");
                li_pb = 0;
                ChaseVariableOverTime(li_pb, 100, S_BUFF_CD[9], TimeChaseReevaluation.None);

                break;
        }
    }
}

void CreateOrb() "[Buff] :: Create Orb"
{
    can_pickup_buff[buff_i] = true;
    buff_timer[buff_i] = false;
    PlayEffect(all, PlayEffect.GoodPickupEffect, color_arr[buff_i], buff_pos[buff_i], 1);

    PlayEffect(all, PlayEffect.RingExplosion, color_arr[buff_i], buff_pos[buff_i], 3);
    PlayEffect(all, PlayEffect.RingExplosion, color_arr[buff_i], buff_pos[buff_i] + Vector(0, -0.5, 0), 2);
    PlayEffect(all, PlayEffect.RingExplosion, color_arr[buff_i], buff_pos[buff_i] + Vector(0, -1, 0), 1);

    switch (buff_i)
    {
        case (0):
            LogToInspector("Wallbang Orb Created");
            StopChasingVariable(wallbang_pb);
            break;
        case (1):
            LogToInspector("Ricochet Orb Created"); 
            StopChasingVariable(ricochet_pb);
            break;
        case (2):
            LogToInspector("Buckshot Orb Created");
            StopChasingVariable(buckshot_pb);
            break;
        case (3):
            LogToInspector("Prism Orb Created");
            StopChasingVariable(prism_pb);
            break;
        case (4):
            LogToInspector("Ballista Orb Created");
            StopChasingVariable(bal_pb);
            break;
        case (5):
            LogToInspector("Electro Orb Created");
            StopChasingVariable(electro_pb);
            break;
        case (6):
            LogToInspector("Spark Orb Created");
            StopChasingVariable(sprk_pb);
            break;
        case (7):
            LogToInspector("Arc Orb Created");
            StopChasingVariable(arc_pb);
            break;
        case (8):
            LogToInspector("Daybreak Orb Created");
            StopChasingVariable(dayb_pb);
            break;
        case (9):
            LogToInspector("Lightning Orb Created");
            StopChasingVariable(li_pb);
            break;
    }
}

rule: "[Buff] :: Remove Current Buff"
Event.OngoingPlayer
if (IsInteractHeld())
if (has_buff)
{
    Wait(1, WaitBehavior.AbortWhenFalse);
    for (Number i = 0; i < 10; i++) // this isnt the best way of doing this. oh well, TODO: do this properly
    {
        DestroyEffect(collected_buff_effect[i]);
        buff_ammo[i] = 0;
        buff_enabled[i] = false;
    }

    has_buff = false;
    PlayEffect(all, PlayEffect.BadPickupEffect, Color.White, PositionOf() + Vector(0, 1, 0.3), 1);
}


