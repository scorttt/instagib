globalvar Number S_MATCH_TIME_LIMIT; // maximum match time
globalvar Number S_PICKUP_RAD; // minimum radius to collect a buff
globalvar Number S_GAMEMODE; // chosen gamemode
globalvar Number[] S_LANG; // chosen language
globalvar Number S_HERO; // gamemode hero
globalvar Number S_DELAY; // weapon fire delay
globalvar Boolean match_started; // has the match started
playervar Boolean info; // information toggle
playervar Boolean pri_override; // disables primary fire (e.g. for owning volt or denial being in use)
playervar Vector gun_pos; // arbitrary position of the gun, it should be the same for sojourn and cassidy
playervar Number delay; // weapon fire delay for the player
playervar Vector first_hp;

Any weapon_muzzle(Vector start_pos, Vector dir): (start_pos + dir) + (WorldVectorOf(Vector(-1, -0.38, 0), player) * 0.14);

disabled rule: "---------------- Main ----------------"{}

rule: "[Main] :: Initial Global"
{
    DisableInspectorRecording();
    DisableCompletion();
    DisableAnnouncer();

    SetMatchTime(1);

    match_started = false;

    S_LANG = WorkshopSettingCombo("General",                                 "Language / 言語 / 언어", 0, ["English", "日本語", "한국어"], 0);
    S_GAMEMODE = WorkshopSettingCombo("General",                             "Gamemode", 0, ["Deathmatch", "Team Deathmatch", "4TDM", "Limited Lives (TDM)", "Freeze Tag (TDM)", "Keepaway (FFA)", "Keepaway (TDM)", "Domination (TDM)", "Domination (4TDM)"], 1);
    S_HERO = WorkshopSettingCombo("General",                                 "Hero", 0, ["Sojourn", "Cassidy"], 2);
    S_MATCH_TIME_LIMIT = WorkshopSettingInteger("General",                   "Match Time (Minutes) (20)", 20, 1, 60, 3) * 60;
    S_PICKUP_RAD = WorkshopSettingReal("General",                            "Pickup Collection Radius (1.25)", 1.25, 0.5, 3, 4);
    S_DELAY = WorkshopSettingReal("General",                                 "Weapon Fire Delay (1)", 1, 0.5, 2, 5);

    s_sec_enabled = WorkshopSettingToggle("Blaster (Secondary Fire)",        "Enable Blaster (On)", true, 1);
    S_SEC_PSPEED = WorkshopSettingReal("Blaster (Secondary Fire)",           "Projectile Speed (90)", 90, 1, 500, 3);
