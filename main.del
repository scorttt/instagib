    S_DODGE_FORCE = WorkshopSettingReal("Dodge",                             "Dodge Strength (14)", 14, 1, 100, 2);
    S_DODGE_AMT = WorkshopSettingInteger("Dodge",                            "Dodge Amount (2)", 2, 1, 100, 3);

    s_bhop_enabled = WorkshopSettingToggle("Bunny Hopping",                  "Enable Bunny Hopping (On)", true, 1);
    S_BHOP_MAX_SPEED = WorkshopSettingInteger("Bunny Hopping",               "Maximum Speed Multiplier From Bunny Hopping (100000)", 100000, 110, 100000, 2);
    S_BHOP_SPEED_RATE = WorkshopSettingReal("Bunny Hopping",                 "Speed gain rate (13.5)", 13.5, 1, 100, 3);

    s_buffs_enabled = WorkshopSettingToggle("Buffs",                         "Enable Buffs (On)", true, 1);
    s_rand_buff_pos = WorkshopSettingToggle("Buffs",                         "Randomize Buff Locations (On)", true, 2);

