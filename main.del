    S_BUFF_CD[0] = WorkshopSettingInteger("Pierce Buff",                     "Pierce Spawn Time (75)", 75, 5, 600, 2);
    S_BUFF_AMMO[0] = WorkshopSettingInteger("Pierce Buff",                   "Pierce Ammo (20)", 20, 1, 1000, 3);
