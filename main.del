                                    ? buff_txt[8] 
                                    : IconString(Icon.Checkmark)>,
            "Delayed cylinder shaped explosion that ignores surfaces", Location.Left, 6, color_arr[8], color_arr[8]);

            CreateHudText(local.buff_enabled[8] ? local : null, null, null, 
            <" <0> Daybreak Ammo: <1> / <2>", 
            AbilityIconString(Hero.WreckingBall, Button.Ability2), local.buff_ammo[8], S_BUFF_AMMO[8]>, 
            Location.Top, 1, TextColor: color_arr[8]);

            CreateHudText(FilteredArray(all, !Curr().info), AbilityIconString(Hero.WreckingBall, Button.Ability2), null,
            dayb_pb != 100 ? buff_txt[8] : IconString(Icon.Checkmark),
            Location.Left, 6, color_arr[8], color_arr[8]);

            CreateEffect(dayb_pb == 100 ? all : null, Effect.Orb, color_arr[8], buff_pos[8], 2, EffectRev.VisibleTo);
            CreateInWorldText(dayb_pb == 100 ? all : null, AbilityIconString(Hero.WreckingBall, Button.Ability2), buff_pos[8] + Vector(0, 0.4, 0), 2, Clipping.ClipAgainstSurfaces, InworldTextRev.VisibleToAndPosition);
        
            if (s_cd_ip_timer)
            {
                CreateEffect(dayb_pb == 100 ? all : null, Effect.LightShaft, color_arr[8], buff_pos[8], 0.035, EffectRev.VisibleTo);
                CreateEffect(dayb_pb != 100 ? all : null, Effect.Sphere, color_arr[8], buff_pos[8], dayb_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateEffect(all, Effect.GoodAura, color_arr[8], buff_pos[8], dayb_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateEffect(all, Effect.Sparkles, color_arr[8], buff_pos[8], dayb_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateProgressBarInWorldText(dayb_pb != 100 ? all : null, dayb_pb, null, buff_pos[8] + Vector(0, dayb_pb * 0.0045, 0), 0, Clipping.ClipAgainstSurfaces, color_arr[8], Color.White, InWorldProgressBarEvaluation.VisibleToPositionAndValues);
            }
        }
    }

    if (s_spawn_m)
    {
        m_rare = true;
        m_in_timer = true;
        
        CreateProgressBarInWorldText(m_wo_timer && mut_pb != 100 ? all : null, mut_pb, null, m_pos + Vector(0, mut_pb * 0.0045, 0), 0, Clipping.ClipAgainstSurfaces, m_color, Color.White, InWorldProgressBarEvaluation.VisibleToPositionValuesAndColor);
        CreateInWorldText(m_wo_timer && mut_pb == 100 ? all : null, m_str, m_pos + Vector(0, 0.45, 0), 2, Clipping.ClipAgainstSurfaces, InworldTextRev.VisibleToPositionAndString);
        CreateEffect(m_wo_timer ? all : null, Effect.BadAura, m_color, m_pos, mut_pb * 0.0045, EffectRev.VisibleToPositionRadiusAndColor);
        CreateEffect(m_wo_timer ? all : null, Effect.GoodAura, m_color, m_pos, mut_pb * 0.0045, EffectRev.VisibleToPositionRadiusAndColor);
        CreateEffect(m_wo_timer ? all : null, Effect.Sparkles, m_color, m_pos, mut_pb * 0.0045, EffectRev.VisibleToPositionRadiusAndColor);
    }

    if (s_sec_enabled || s_bhop_enabled || s_dodge_enabled)
        CreateHudText(FilteredArray(all, Curr().info), null, " \nMovement", null, Location.Left, 15);

    if (s_bhop_enabled)
    {
        CreateHudText(FilteredArray(all, Curr().info), 
        AbilityIconString(Hero.Baptiste, Button.Crouch), 
        "Bunny Hopping", 
        <"Holding down <0> while moving will allow you to gain speed", InputBindingString(Button.Jump)>, Location.Left, 16, Color.Aqua, Color.Aqua);
    }

    if (s_sec_enabled)
    {
        CreateHudText(FilteredArray(all, Curr().info), 
        AbilityIconString(Hero.Pharah, Button.Ability2), 
        "Blaster", 
        <"Press <0> to fire a projectile that pushes you and other players away", InputBindingString(Button.SecondaryFire)>, Location.Left, 17, Color.Red, Color.Red);
    }

    if (s_dodge_enabled)
    {
        CreateHudText(FilteredArray(all, Curr().info), 
        AbilityIconString(Hero.Soldier76, Button.Ability1), 
        "Dodge", 
        <"Press <0> while in air to dodge in any direction", InputBindingString(Button.Ability1)>, Location.Left, 18, Color.Gray, Color.Gray);
    }
}

rule: "[Main] :: Player Join"
Event.OnPlayerJoin
{
    if (IsDummyBot())
        SetRespawnMaxTime(player, 1);

    DisableGameModeHud();

    DisallowButton(player, Button.PrimaryFire);
    DisallowButton(player, Button.Ability1);
    DisallowButton(player, Button.Ability2);

    DbgPlayer();

    charge_str = "○ ○ ○ ○ ○ ";
    sec_eyepos = Vector(-10000, -10000, -10000);
    sprk_eyepos = Vector(-10000, -10000, -10000);
    electro_eyepos1 = Vector(-10000, -10000, -10000);
    electro_eyepos2 = Vector(-10000, -10000, -10000);
    electro_eyepos3 = Vector(-10000, -10000, -10000);
    bhop_speed = 100;
}

rule: "[Main] :: Server Fire and Delay"
Event.OngoingPlayer
if (!pri_override)
if (IsPrimaryHeld())
{
    AllowButton(player, Button.PrimaryFire);
    PressButton(player, Button.PrimaryFire);
    MinWait();
    DisallowButton(player, Button.PrimaryFire);
    Wait(1);
    LoopIfConditionIsTrue();
}

rule: "[Main] :: Info Toggle"
Event.OngoingPlayer
if (IsMeleeHeld())
{
    WaitIfTrue(0.5);

    info = !info;
    if (info)
        DisableTextChat(player);
    else
        EnableTextChat(player);
}

rule: "[Main] :: Player Spawned"
Event.OngoingPlayer
if (HasSpawned())
{
    CreateEffect(bhopping ? all : null, Effect.Soldier76SprintingEffect, Color.White, player, 1);
}

rule: "[Main] :: Automatically Force McCree"
Event.OngoingPlayer
if (!HasSpawned())
{
    ForcePlayerHero(player, Hero.Mccree);
    Wait(1);
    LoopIfConditionIsTrue();
}

rule: "[Main] :: End Game"
if (match_started)
if (MatchTime() <= 0)
{
    EnableCompletion();
}

rule: "[Main] :: Start Primary Override"
Event.OngoingPlayer
if (buff_enabled[4] || buff_enabled[7])
{
    pri_override = true;
}

rule: "[Main] :: Stop Primary Override"
Event.OngoingPlayer
if (!buff_enabled[4] && !buff_enabled[7])
{
    pri_override = false;
}
