                    Vector(2.00, 2, -8.64),
                    Vector(-9.24, -5.37, 43.78),
                    Vector(2.00, -8.98, 9.00),
                    Vector(2.07, 0, 33.79),
                    Vector(1.96, -5, -13.11),
                    Vector(35.86, -8.98, 28.09),
                    Vector(1.96, 1.5, 7.32),
                    Vector(-28.00, -4.00, 21.00)];

            m_loc = [Vector(-11.43, -9, 8.87),
                    Vector(26.13, -3, -6.99),
                    Vector(26.92, -4.51, 31.75),
                    Vector(-20.50, -5.06, 55.07),
                    Vector(-32.27, 1, -5.06)];
            
            break;
        case (IsMap(Map.Oasis_City_Center)):
            valid_map = true;
            b_loc = [Vector(164.76, 5, 226.22),
                    Vector(122.22, 5, 268.75),
                    Vector(154.48, 12.52, 258.48),
                    Vector(118.01, 2, 221.96),
                    Vector(143.48, 3.15, 247.50),
                    Vector(158.69, 5, 262.68),
                    Vector(125.12, 2.85, 291.32),
                    Vector(187.39, 2.85, 229.09),
                    Vector(128.29, 5, 232.29)];
            
            break; 
        case (IsMap(Map.Oasis_University)):
            valid_map = true;
            b_loc = [Vector(-188, 16, -38),
                    Vector(-188, 16, 38),
                    Vector(-172, 18, 0),
                    Vector(-188, 17, 0),
                    Vector(-217.72, 20, 0),
                    Vector(-188, 10.40, 0),
                    Vector(-188, 17, 18),
                    Vector(-188, 17, -18),
                    Vector(-207.92, 20, 0)];

            break; 
        case (IsMap(Map.Oasis_Gardens)):
            valid_map = true;
            b_loc = [Vector(115.06, 8.50, -273.62),
                    Vector(167.40, 8.50, -221.28),
                    Vector(107.79, 5.50, -214.08),
                    Vector(152.05, 8.54, -258.26),
                    Vector(121.35, 12.50, -227.56),
                    Vector(87.4, 3.50, -248.25),
                    Vector(142, 3.50, -193.60),
                    Vector(141.35, 8.38, -247.59),
                    Vector(126.23, 6.50, -232.46)];
            
            break;
        default: 
            valid_map = false;
            break;
    }

    num b_len = b_loc.Length;
    if (valid_map)
    {
        if (s_buffs_enabled)
        {
            for (num i = 0; i < b_len; i++)
            {   
                vec chosen_b_pos;

                if (s_rand_buff_pos)
                    chosen_b_pos = b_loc.Random(); 
                else 
                    chosen_b_pos = b_loc.First; 

                b_loc -= chosen_b_pos; 
                buff_pos[i] = chosen_b_pos;

                if (s_dbg_fastspawn[0])
                    S_BUFF_CD[i] = 5;

                buff_cd[i] = S_BUFF_CD[i];
            }
        }
        
        if (s_spawn_m)
        {
            if (s_rand_mcd)
            {
                num rand = RandomInteger(0, 60);
                m_cd = S_M_CD + rand;
            }
            else 
            {
                m_cd = S_M_CD;
            }
        }
    }

    CreateHudText(all, null, "ㅤInstagib | Created by scort#11221 ", null, Location.Right, 0, Color.White, Color.White, Color.White, HudTextRev.VisibleTo);
    CreateHudText(all, null, "ㅤv2.0 | Code: APPPX ", null, Location.Right, 0.1, Color.White, Color.White, Color.White, HudTextRev.VisibleTo);
}

rule: "[Main] :: Start Match"
if (!match_started)
if (IsGameInProgress())
if (all_living.Length >= 1)
{
    LogToInspector("Match Started");
    SetMatchTime(S_MATCH_TIME_LIMIT);
    match_started = true;

    if (valid_map && s_buffs_enabled)
    {
        for (num i = 0; i < S_BUFF_CD.Length; i++)
        {
            buff_i = i;
            BuffCooldown();
        }

        CreateHudText(FilteredArray(all, !Curr().info), null, <" \nHold <0> for help", InputBindingString(Button.Melee)>, null, Location.Left, 20);
        CreateHudText(FilteredArray(all, Curr().info), null, 
        <" \nHold <0> to hide (Chat is Disabled)\nHold <1> to remove your currently held buff", 
        InputBindingString(Button.Melee), InputBindingString(Button.Interact)>, null, Location.Left, 20);

        if (s_spawn_buff[0])
        {
            CreateHudText(FilteredArray(all, Curr().info), 
            AbilityIconString(Hero.Baptiste, Button.Ultimate), 
            <"Wallbang  |  <0>", wallbang_pb != 100 
                                    ? buff_txt[0] 
                                    : IconString(Icon.Checkmark)>, 
            "Pierce through surfaces", Location.Left, 1, color_arr[0], color_arr[0]);

            CreateHudText(local.buff_enabled[0] ? local : null, null, null, 
            <" <0> Wallbang Ammo: <1> / <2>", 
            AbilityIconString(Hero.Baptiste, Button.Ultimate), local.buff_ammo[0], S_BUFF_AMMO[0]>, 
            Location.Top, 1, TextColor: color_arr[0]);

            CreateHudText(FilteredArray(all, !Curr().info), AbilityIconString(Hero.Baptiste, Button.Ultimate), null,
            wallbang_pb != 100 ? buff_txt[0] : IconString(Icon.Checkmark),
            Location.Left, 1, color_arr[0], color_arr[0]);

            CreateEffect(wallbang_pb == 100 ? all : null, Effect.Orb, color_arr[0], buff_pos[0], 2, EffectRev.VisibleTo);
            CreateInWorldText(wallbang_pb == 100 ? all : null, AbilityIconString(Hero.Baptiste, Button.Ultimate), buff_pos[0] + Vector(0, 0.4, 0), 2, Clipping.ClipAgainstSurfaces, InworldTextRev.VisibleToAndPosition);
            
            if (s_cd_ip_timer)
            {
                CreateEffect(wallbang_pb == 100 ? all : null, Effect.LightShaft, color_arr[0], buff_pos[0], 0.035, EffectRev.VisibleTo);
                CreateEffect(wallbang_pb != 100 ? all : null, Effect.Sphere, color_arr[0], buff_pos[0], wallbang_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateEffect(all, Effect.GoodAura, color_arr[0], buff_pos[0], wallbang_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateEffect(all, Effect.Sparkles, color_arr[0], buff_pos[0], wallbang_pb * 0.0045, EffectRev.VisibleToPositionAndRadius);
                CreateProgressBarInWorldText(wallbang_pb != 100 ? all : null, wallbang_pb, null, buff_pos[0] + Vector(0, wallbang_pb * 0.0045, 0), 0, Clipping.ClipAgainstSurfaces, color_arr[0], Color.White, InWorldProgressBarEvaluation.VisibleToPositionAndValues);
            }
        }

        if (s_spawn_buff[1])
