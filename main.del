    S_ELECTRO_PDELAY = WorkshopSettingReal("Electro Buff",                   "Electro Grenade Delay After Hitting a surface (0.5)", 0.5, 0.1, 2, 4);
    S_ELECTRO_PRAD = WorkshopSettingReal("Electro Buff",                     "Electro Grenade Radius (8)", 8, 1, 20, 5);
