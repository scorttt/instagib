rule: "[Main] :: Info Toggle"
Event.OngoingPlayer
if (IsMeleeHeld())
{
    WaitIfTrue(0.5);

    info = !info;
    if (info)
        DisableTextChat(player);
    else
        EnableTextChat(player);
}

rule: "[Main] :: Automatically Force Hero"
Event.OngoingPlayer
if (!HasSpawned())
{
    if (S_HERO == 0)
        ForcePlayerHero(player, Hero.Cassidy); // todo: change this to sojourn once OW2 gets workshop support
    else
        ForcePlayerHero(player, Hero.Cassidy);

    Wait(1);
    LoopIfConditionIsTrue();
}

rule: "[Main] :: End Game"
if (match_started)
if (MatchTime() <= 0)
{
    EnableCompletion();
}

