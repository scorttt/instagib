    S_BUFF_AMMO[8] = WorkshopSettingInteger("Nebula Buff",                   "Nubla Ammo", 100, 1, 1000, 3);

    s_spawn_buff[9] = WorkshopSettingToggle("Volt Buff",                     "Spawn Volt (On)", true, 1);
    S_BUFF_CD[9] = WorkshopSettingInteger("Volt Buff",                       "Volt Spawn Time (165)", 165, 5, 600, 2);
    S_BUFF_AMMO[9] = WorkshopSettingReal("Volt Buff",                        "Volt Ammo (250)", 250, 1, 10000, 3);
    S_MAX_VLT_SPREAD = WorkshopSettingReal("Volt Buff",                      "Volt Maximum Spread (Lower is Tighter) (20)", 20, 0, 100, 4) / 100;
    S_MAX_VLT_DIST = WorkshopSettingReal("Volt Buff",                        "Volt Maximum Distance (100)", 100, 1, 300, 5);
    S_MIN_VLT_DIST = WorkshopSettingReal("Volt Buff",                        "Volt Minimum Distance (1)", 1, 0.5, 300, 6);
    S_VLT_TIME = WorkshopSettingReal("Volt Buff",                            "Volt Overheat Time (5)", 5, 0.1, 10, 7);

    s_enable_m = WorkshopSettingToggle("Mutators",                           "Enable Mutators (On)", true, 1);
    s_rand_mcd = WorkshopSettingToggle("Mutators",                           "Randomize Relative Spawn Time (On)", true, 2);
    S_M_CD = WorkshopSettingInteger("Mutators",                              "Mutator Spawn Time (180)", 180, 5, 600, 3);
    S_M_CREATION = WorkshopSettingInteger("Mutators",                        "Mutator Creation Time (15)", 15, 1, 600, 4);
    S_M_DURATION = WorkshopSettingInteger("Mutators",                        "Mutator Duration (40)", 40, 5, 600, 5);

    s_spawn_mut[6] = WorkshopSettingToggle("Mutators",                       "Spawn Denial (On)", true, 1);

    # please do not remove any credit from this list unless you have completely changed the relevant contents
    Number[] credit;
    credit[0] = WorkshopSettingCombo("Credit",                               "Main Developer", 0, ["scort#11221"], 0);
    credit[1] = WorkshopSettingCombo("Credit",                               "JP Localization", 0, ["saruyo"], 1);
    credit[2] = WorkshopSettingCombo("Credit",                               "Air Drag", 0, ["T1mur4TR"], 2);

    if (!s_buffs_enabled)
        for (Number i = 0; i < s_spawn_buff.Length; i++)
            s_spawn_buff[i] = false;
}

rule: "[Main] :: Start Match"
if (!match_started)
if (IsGameInProgress())
if (all_living.Length >= 1)
{
    LogToInspector("Match Started");
    SetMatchTime(S_MATCH_TIME_LIMIT);
    match_started = true;

    if (valid_map && s_buffs_enabled)
    {
        for (Number i = 0; i < S_BUFF_CD.Length; i++)
        {
            buff_i = i;
            BuffCooldown();
        }
    }
}

rule: "[Main] :: Player Join/Init"
Event.OnPlayerJoin
{
    DisallowButton(player, Button.PrimaryFire);
    DisallowButton(player, Button.SecondaryFire);
    DisallowButton(player, Button.Ability1);
    DisallowButton(player, Button.Ability2);

    if (S_HERO == 0)
        SetAbilityResource(player, Button.SecondaryFire, 100);

    if (valid_map)
    {
        CreateEffect(IsAlive() && has_buff && !HasStatus(player, Status.PhasedOut) ? all : null, Effect.GoodAura, buff_color, player, 0.5, EffectRev.VisibleToPositionRadiusAndColor);
        CreateEffect(IsAlive() && has_mut ? all : null, Effect.BadAura, m_color[1], player, 0.5, EffectRev.VisibleToPositionRadiusAndColor);
    }

    // check ballista and seer users and apply outlines to the new player
    if (FilteredArray(all, Curr().buff_enabled[4] && Curr().bal_chrg >= 75).Length > 0)
        StartForcingPlayerOutlines(player, FilteredArray(all, Curr().buff_enabled[4] && Curr().bal_chrg >= 75), true, color_arr[4], OutlineType.Always);
    if (m_usr != null && m_usr.m_enabled[0])
        StartForcingPlayerOutlines(player, m_usr, true, m_color[1], OutlineType.Always);

    DisableGameModeHud();
    StartScalingPlayer(player, 0.80);

    bhop_mult = 100;
    bhop_speed = bhop_mult;
    bhop_rate = S_BHOP_SPEED_RATE;
    delay = S_DELAY;
    has_buff = false;
    has_mut = false;
}

void FireWeapon(in Button button, in Number wait)
{
    // if (has_buff)
    {
        gun_pos = weapon_muzzle(EyePosition(), Facing());
        first_hp = RayCastHitPosition(EyePosition(), EyePosition() + Facing() * 300, AllLivingPlayers(), player, true);
    }

    AllowButton(player, button);
    PressButton(player, button);
    MinWait();
    DisallowButton(player, button);
    Wait(wait); // main fire rate delay, must not be lower than 0.5 for Cassidy and 0.7 (?) for Sojourn
}

rule: "[Main] :: Bullet Trail"
Event.OngoingPlayer
if (has_buff)
if (first_hp != null)
{
    if (DistanceBetween(EyePosition(), first_hp) < 300)
        PlayEffect(all, PlayEffect.GoodExplosion, color_arr[buff_held], first_hp, 0.5);

    CreateBeamEffect(all, BeamType.BadBeam, gun_pos, first_hp, color_arr[buff_held], EffectRev.None);
    buff_trail = LastCreatedEntity();

    Wait(0.25);
    first_hp = null;
    DestroyEffect(buff_trail);
}

rule: "[Main] :: Cassidy : Server Fire"
Event.OngoingPlayer
Player.Cassidy
if (!pri_override)
if (IsAlive())
// if (!IsDummyBot())
if (IsPrimaryHeld())
{
    FireWeapon(Button.PrimaryFire, delay);
    LoopIfConditionIsTrue();
}

